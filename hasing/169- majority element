/*
-----------------------------------------
LeetCode 169 - Majority Element

Pattern:
Hashing (Frequency Counting)

Approach:
Store the frequency of every element using an unordered_map.
Traverse the map and return the element whose frequency
is greater than n/2.

Time Complexity: O(n)

Space Complexity: O(n)

Alternative Optimal Solution:
Boyer-Moore Voting Algorithm
Time: O(n)
Space: O(1)

Key Learning:
- Hashing provides a straightforward solution.
- Boyer-Moore optimizes the space complexity to O(1).

-----------------------------------------
*/

BY HASHING
class Solution {
public:
    int majorityElement(vector<int>& nums) {

        unordered_map<int,int> mpp;

        for(int x : nums)
            mpp[x]++;

        for(auto it : mpp)
        {
            if(it.second > nums.size()/2)
                return it.first;
        }

        return -1;
    }
};


BY BOYER-MOORE VOTING ALGOTHRIM 
class Solution {
public:
    int majorityElement(vector<int>& nums) {
        unordered_map<int,int>mpp;
        for(int i=0;i<nums.size();i++)
        {
            mpp[nums[i]]++;
        }
        int max=0;
        for(auto it : mpp)
        {
            if(it.second>nums.size()/2) max=it.first;
        }
        return max;
    }
};
