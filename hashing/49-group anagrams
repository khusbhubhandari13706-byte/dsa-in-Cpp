/*
-----------------------------------------
LeetCode 49 - Group Anagrams
Pattern:Hashing (unordered_map) + Sorting

Approach:
1. Traverse each string in the input array.
2. Create a copy of the current string.
3. Sort the copied string.
4. Use the sorted string as the key in an unordered_map.
5. Store the original string in the corresponding vector.
6. After processing all strings, copy all the values of the map into the answer vector.

Time Complexity:
Let:
n = number of strings
k = average length of each string

Sorting each string takes O(k log k).
Since we sort all n strings:

Overall Time Complexity = O(n × k log k)
Space Complexity:O(n × k)

Key Learning:
- Hash map keys do not always have to be the original data.
- Sometimes transforming the data (sorting in this case) makes grouping much easier.
- unordered_map<string, vector<string>> is useful for grouping similar elements.


-----------------------------------------
*/

class Solution {
public:
    vector<vector<string>> groupAnagrams(vector<string>& strs) {

        unordered_map<string, vector<string>> mpp;

        for(string str : strs)
        {
            string temp = str;

            sort(temp.begin(), temp.end());

            mpp[temp].push_back(str);
        }

        vector<vector<string>> ans;

        for(auto it : mpp)
        {
            ans.push_back(it.second);
        }

        return ans;
    }
};
